model StellarAccount {
  id                    String   @id @default(uuid())
  address               String   @unique @db.VarChar(56)
  xlmBalance            Decimal  @default(0) @db.Decimal(30, 7)
  buyingLiabilities     Decimal  @default(0) @db.Decimal(30, 7)
  sellingLiabilities    Decimal  @default(0) @db.Decimal(30, 7)
  sequenceNumber        BigInt?
  subentryCount         Int      @default(0)
  inflationDestination  String?  @db.VarChar(56)
  homeDomain            String?  @db.VarChar(255)
  homeDomainVerified    Boolean  @default(false)
  flags                 Json?
  thresholds            Json?
  numSigners            Int      @default(0)
  numTrustlines         Int      @default(0)
  numDataEntries        Int      @default(0)
  numClaimableBalances  Int      @default(0)
  isActivated           Boolean  @default(false)
  firstSeen             DateTime?
  lastActivity          DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())

  trustlines AccountTrustline[]
  signers    AccountSigner[]
}

model AccountTrustline {
  id                             BigInt   @id @default(autoincrement())
  accountId                      String
  assetCode                      String   @db.VarChar(12)
  assetIssuer                    String   @db.VarChar(56)
  balance                        Decimal  @default(0) @db.Decimal(30, 7)
  limitAmount                    Decimal? @db.Decimal(30, 7)
  authorized                     Boolean  @default(false)
  authorizedToMaintainLiabilities Boolean @default(false)
  clawbackBalanceSet             Boolean  @default(false)
  isLiquidityPoolShare           Boolean  @default(false)
  lastModified                   DateTime @default(now())

  account StellarAccount @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([accountId, assetCode, assetIssuer])
}

model AccountSigner {
  id           BigInt   @id @default(autoincrement())
  accountId    String
  signerKey    String   @db.VarChar(56)
  signerType   String   @db.VarChar(30)
  weight       Int
  sponsor      String?  @db.VarChar(56)
  lastModified DateTime @default(now())

  account StellarAccount @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([accountId, signerKey])
}

model StellarAsset {
  id                String   @id @default(uuid())
  assetCode         String   @db.VarChar(12)
  assetIssuer       String   @db.VarChar(56)
  assetType         String   @db.VarChar(20)
  totalSupply       Decimal  @default(0) @db.Decimal(30, 7)
  numHolders        Int      @default(0)
  numTrustlines     Int      @default(0)
  volume24h         Decimal  @default(0) @db.Decimal(30, 7)
  trades24h         Int      @default(0)
  isAnchored        Boolean  @default(false)
  anchorName        String?  @db.VarChar(255)
  homeDomain        String?  @db.VarChar(255)
  isBridgedToSoroban Boolean @default(false)
  sorobanContract   String?  @db.VarChar(56)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now())

  @@unique([assetCode, assetIssuer])
}

model UnifiedTransaction {
  id             String   @id @default(uuid())
  sourceAccount  String   @db.VarChar(56)
  network        String   @db.VarChar(20)
  txHash         String   @db.VarChar(64)
  type           String   @db.VarChar(30)
  subType        String?  @db.VarChar(50)
  amount         Decimal? @db.Decimal(30, 7)
  assetCode      String?  @db.VarChar(12)
  assetIssuer    String?  @db.VarChar(56)
  destination    String?  @db.VarChar(56)
  fee            Decimal? @db.Decimal(30, 7)
  memoType       String?  @db.VarChar(20)
  memoContent    String?
  successful     Boolean
  createdAt      DateTime
  ledgerSequence Int?
  operations     Json?

  @@unique([network, txHash])
  @@index([sourceAccount, createdAt])
}

model AnchorsRegistry {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(255)
  homeDomain     String   @db.VarChar(255)
  address        String?  @db.VarChar(56)
  assets         Json
  regions        String[]
  kycRequired    Boolean  @default(false)
  kycTypes       String[]
  fees           Json?
  limits         Json?
  supportedSeps  String[]
  isVerified     Boolean  @default(false)
  rating         Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount    Int      @default(0)
  status         String   @default("active") @db.VarChar(20)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  reviews AnchorReview[]

  @@index([homeDomain])
  @@index([status])
}

model AnchorReview {
  id        String   @id @default(uuid())
  anchorId  String
  reviewer  String   @db.VarChar(56)
  rating    Decimal  @db.Decimal(3, 2)
  comment   String?
  createdAt DateTime @default(now())

  anchor AnchorsRegistry @relation(fields: [anchorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([anchorId])
}

model BridgedAsset {
  id                    String   @id @default(uuid())
  classicAssetCode      String   @db.VarChar(12)
  classicAssetIssuer    String   @db.VarChar(56)
  sorobanContract       String   @unique @db.VarChar(56)
  bridgeProtocol        String   @db.VarChar(50)
  bridgeContract        String?  @db.VarChar(56)
  totalSupplyClassic    Decimal? @db.Decimal(30, 7)
  totalSupplySoroban    Decimal? @db.Decimal(30, 7)
  circulationClassic    Decimal? @db.Decimal(30, 7)
  circulationSoroban    Decimal? @db.Decimal(30, 7)
  lockedInBridge        Decimal? @db.Decimal(30, 7)
  totalBridgedVolume    Decimal? @db.Decimal(30, 0)
  bridgeFee             Decimal? @db.Decimal(5, 4)
  status                String   @default("active") @db.VarChar(20)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())
}

model StellarNetworkHealth {
  id                      BigInt   @id @default(autoincrement())
  nodeCount               Int?
  organizationCount       Int?
  countriesCount          Int?
  consensusRoundTimeMs    Int?
  ledgerCloseTimeMs       Int?
  latestLedgerSequence    BigInt?
  protocolVersion         Int?
  scpMessagesPerSecond    Decimal? @db.Decimal(10, 2)
  networkQuorumSet        Json?
  topOrganizations        Json?
  collectedAt             DateTime @default(now())
}

// =========================================================================
// Migration: 20260618000000_cross_contract_composability
// =========================================================================

model ComposedTransaction {
  id              String   @id
  txHash          String   @unique
  ledgerSeq       Int
  timestamp       DateTime
  contractCalls   Json?
  callGraph       Json?
  safetyScore     Float?
  riskLevel       String?
  analysisStatus  String   @default("pending")
  createdAt       DateTime @default(now())

  patternInstances CompositionPatternInstance[]

  @@index([ledgerSeq])
  @@index([riskLevel])
  @@index([analysisStatus])
}

model CompositionPattern {
  id              String   @id
  name            String   @unique
  description     String
  category        String
  riskRating      String   @default("medium_risk")
  requiredCalls   Int      @default(2)
  detectionRules  Json?
  safeIf          Json?
  mitigationGuide String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patternInstances CompositionPatternInstance[]
  alerts           CompositionAlert[]

  @@index([category])
  @@index([riskRating])
}

model CompositionPatternInstance {
  id         String   @id
  txId       String
  patternId  String
  confidence Float
  details    Json?
  createdAt  DateTime @default(now())

  transaction ComposedTransaction @relation(fields: [txId], references: [id], onUpdate: Cascade)
  pattern     CompositionPattern  @relation(fields: [patternId], references: [id], onUpdate: Cascade)

  @@index([txId])
  @@index([patternId])
}

model ContractComposability {
  id                  String   @id
  contractId          String
  contractAddress     String   @unique
  composedWith        Json?
  compositionCount    Int      @default(0)
  uniqueCallers       Int      @default(0)
  uniqueCallees       Int      @default(0)
  avgCompositionDepth Float?
  safetyScoreAvg      Float?
  riskIncidents       Int      @default(0)
  lastAnalyzed        DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([contractAddress])
  @@index([riskIncidents])
}

model CompositionAlert {
  id              String    @id
  txHash          String?
  contractAddress String?
  patternId       String?
  severity        String
  title           String
  description     String
  exploitDetected Boolean   @default(false)
  mitigated       Boolean   @default(false)
  mitigationPatch Json?
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  pattern CompositionPattern? @relation(fields: [patternId], references: [id], onUpdate: Cascade)

  @@index([txHash])
  @@index([contractAddress])
  @@index([severity])
  @@index([exploitDetected])
}

model ComposabilityStaticAnalysis {
  id                    String   @id
  contractAddress       String   @unique
  externalCalls         Json?
  callGraph             Json?
  circularDeps          Json?
  hasUnboundedRecursion Boolean  @default(false)
  maxCallDepth          Int      @default(0)
  analysisVersion       String   @default("1.0")
  analyzedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
